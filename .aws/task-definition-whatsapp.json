{
  "family": "grupolink-whatsapp-service",
  "cpu": "512",
  "memory": "1024",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "executionRoleArn": "arn:aws:iam::985818273645:role/grupolink-prod-task-execution-role",
  "taskRoleArn": "arn:aws:iam::985818273645:role/grupolink-prod-task-role",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "ARM64"
  },
  "volumes": [
    {
      "name": "sessions",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-00e54586f53f0a468",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED"
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "grupolink-whatsapp-service",
      "image": "985818273645.dkr.ecr.us-east-1.amazonaws.com/grupolink-whatsapp-service:latest",
      "portMappings": [
        {
          "name": "whatsapp-service-3001",
          "containerPort": 3001,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "sessions",
          "containerPath": "/app/sessions",
          "readOnly": false
        }
      ],
      "environment": [
        { "name": "PORT",         "value": "3001" },
        { "name": "SESSIONS_DIR", "value": "/app/sessions" },
        { "name": "LOG_LEVEL",    "value": "info" }
      ],
      "secrets": [
        { "name": "API_SECRET",          "valueFrom": "arn:aws:ssm:us-east-1:985818273645:parameter/grupolink/WHATSAPP_SERVICE_SECRET" },
        { "name": "BACKEND_WEBHOOK_URL", "valueFrom": "arn:aws:ssm:us-east-1:985818273645:parameter/grupolink/BACKEND_WEBHOOK_URL" },
        { "name": "BACKEND_API_SECRET",  "valueFrom": "arn:aws:ssm:us-east-1:985818273645:parameter/grupolink/BACKEND_API_SECRET" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/grupolink-whatsapp-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "essential": true
    }
  ]
}