PORT=3001
API_SECRET=dev-secret-change-in-production
SESSIONS_DIR=./sessions
LOG_LEVEL=info

# ── Webhook para o backend (monitoramento de grupos) ─────────────
# URL para onde mensagens com link "https://meli.la/..." capturadas em
# grupos monitorados são enviadas. Deve apontar para o backend Kotlin.
BACKEND_WEBHOOK_URL=http://localhost:8080/api/webhooks/whatsapp/internal/message
# Mesmo segredo configurado em app.whatsapp-service.secret no backend
BACKEND_API_SECRET=dev-secret-change-in-production
